# Copy this file to .env.prod on your EC2 host.
# Do not commit real secrets.

# Image tags consumed by docker-compose.prod.yml
FRONTEND_IMAGE=ghcr.io/<owner>/vswrite-frontend:latest
BACKEND_IMAGE=ghcr.io/<owner>/vswrite-backend:latest

# Frontend build-time auth key (used in CD build args)
VITE_GOOGLE_CLIENT_ID=

# Backend runtime
DATA_STORE=postgres
CORS_ORIGIN=https://your-domain.example

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=vswrite
DATABASE_URL=postgresql://postgres:replace-with-strong-password@postgres:5432/vswrite?schema=public

# Redis
REDIS_URL=redis://redis:6379
